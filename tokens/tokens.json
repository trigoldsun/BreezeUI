{
  "$schema": "https://design-tokens.org/schema/v1.0.0.json",
  "name": "BreezeUI",
  "version": "1.0.0",
  "prefix": "breeze",
  "themes": [
    "default",
    "breeze-dark",
    "breeze-warm",
    "breeze-dream"
  ],
  "colors": {
    "background": {
      "primary": {
        "default": "#F8FAFE"
      },
      "secondary": {
        "default": "#EEF3FA"
      },
      "elevated": {
        "default": "#FFFFFF"
      },
      "overlay": {
        "default": "#DDE5F0"
      },
      "input": {
        "default": "#F0F5FC"
      },
      "hover": {
        "default": "#E8F0FB"
      },
      "active": {
        "default": "#DDE8F5"
      },
      "subtle": {
        "default": "#F5F8FE"
      }
    },
    "accent": {
      "primary": {
        "default": "#4A9FFF"
      },
      "secondary": {
        "default": "#36D399"
      },
      "tertiary": {
        "default": "#FF9F43"
      },
      "warm": {
        "default": "#FF6B9D"
      }
    },
    "functional": {
      "success": "#22C55E",
      "warning": "#F59E0B",
      "danger": "#EF4444",
      "info": "#4A9FFF"
    },
    "pastel": {
      "blue": "#DBEAFE",
      "green": "#D1FAE5",
      "orange": "#FEF3C7",
      "pink": "#FCE7F3",
      "gray": "#F1F5F9"
    },
    "text": {
      "primary": {
        "default": "#1E3A5F"
      },
      "secondary": {
        "default": "#5A7A9A"
      },
      "tertiary": {
        "default": "#94A8BE"
      },
      "inverse": {
        "default": "#FFFFFF"
      },
      "link": "#4A9FFF",
      "muted": {
        "default": "#7C9AB8"
      }
    },
    "border": {
      "default": {
        "default": "rgba(74,159,255,0.15)"
      },
      "hover": {
        "default": "rgba(74,159,255,0.4)"
      },
      "focus": "#4A9FFF",
      "active": {
        "default": "rgba(54,211,153,0.5)"
      },
      "subtle": {
        "default": "rgba(74,159,255,0.08)"
      }
    }
  },
  "typography": {
    "fonts": {
      "display": "'Nunito', 'Noto Sans SC', system-ui",
      "body": "'DM Sans', 'PingFang SC', 'Microsoft YaHei', sans-serif",
      "mono": "'JetBrains Mono', 'Fira Code', monospace"
    },
    "sizes": {
      "2xs": "0.625rem",
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "2rem",
      "4xl": "2.5rem",
      "5xl": "3rem"
    },
    "weights": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "0": "0",
    "px": "0.0625rem",
    "0-5": "0.125rem",
    "1": "0.25rem",
    "1-5": "0.375rem",
    "2": "0.5rem",
    "2-5": "0.625rem",
    "3": "0.75rem",
    "3-5": "0.875rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "7": "1.75rem",
    "8": "2rem",
    "9": "2.25rem",
    "10": "2.5rem",
    "12": "3rem",
    "14": "3.5rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem",
    "32": "8rem"
  },
  "borderRadius": {
    "none": "0",
    "sm": "6px",
    "md": "12px",
    "lg": "18px",
    "xl": "24px",
    "2xl": "32px",
    "full": "9999px"
  },
  "transition": {
    "duration": {
      "instant": "0ms",
      "fast": "100ms",
      "normal": "180ms",
      "slow": "280ms",
      "slower": "400ms",
      "slowest": "600ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "inOut": "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.34, 1.3, 0.64, 1)",
      "smooth": "cubic-bezier(0.25, 0.46, 0.45, 0.94)"
    }
  },
  "shadow": {
    "xs": "0 1px 2px rgba(30,58,95,0.05)",
    "sm": "0 2px 6px rgba(30,58,95,0.08)",
    "md": "0 4px 16px rgba(30,58,95,0.1)",
    "lg": "0 8px 28px rgba(30,58,95,0.12)",
    "xl": "0 16px 48px rgba(30,58,95,0.15)",
    "inner": "inset 0 1px 3px rgba(30,58,95,0.06)",
    "float": "0 8px 32px rgba(30,58,95,0.12)"
  },
  "glow": {
    "primary": "0 4px 16px rgba(74,159,255,0.25)",
    "secondary": "0 4px 16px rgba(54,211,153,0.2)",
    "success": "0 4px 12px rgba(34,197,94,0.25)",
    "warning": "0 4px 12px rgba(245,158,11,0.25)",
    "danger": "0 4px 12px rgba(239,68,68,0.25)",
    "warm": "0 4px 16px rgba(255,107,157,0.2)"
  },
  "zIndex": {
    "base": 0,
    "raised": 10,
    "dropdown": 100,
    "sticky": 200,
    "fixed": 300,
    "modal": 400,
    "toast": 500,
    "tooltip": 600
  },
  "component": {
    "height": {
      "xs": "26px",
      "sm": "34px",
      "md": "42px",
      "lg": "50px",
      "xl": "58px",
      "2xl": "66px"
    },
    "width": {
      "sm": "80px",
      "md": "120px",
      "lg": "200px",
      "xl": "280px",
      "full": "100%"
    }
  },
  "aliases": {
    "$aliasSchema": "https://design-tokens.org/schema/v1.0.0.json#alias",
    "button": {
      "primary": {
        "background": "{colors.accent.primary}",
        "text": "{colors.text.inverse}",
        "border": "{colors.accent.primary}",
        "hover": {
          "background": "{colors.accent.primary}",
          "shadow": "{glow.primary}"
        }
      },
      "secondary": {
        "background": "{colors.accent.secondary}",
        "text": "{colors.text.inverse}",
        "border": "{colors.accent.secondary}"
      },
      "ghost": {
        "background": "transparent",
        "text": "{colors.accent.primary}",
        "border": "transparent"
      }
    },
    "input": {
      "default": {
        "background": "{colors.background.input}",
        "border": "{colors.border.default}",
        "text": "{colors.text.primary}",
        "placeholder": "{colors.text.tertiary}"
      },
      "focus": {
        "border": "{colors.border.focus}",
        "shadow": "{glow.primary}"
      },
      "error": {
        "border": "{colors.functional.danger}",
        "shadow": "{glow.danger}"
      }
    },
    "card": {
      "elevated": {
        "background": "{colors.background.elevated}",
        "shadow": "{shadow.md}",
        "border": "{colors.border.subtle}"
      },
      "primary": {
        "background": "{colors.background.secondary}",
        "shadow": "{shadow.sm}",
        "border": "{colors.border.default}"
      }
    },
    "badge": {
      "success": {
        "background": "{colors.functional.success}",
        "backgroundLight": "rgba(34,197,94,0.12)",
        "text": "{colors.functional.success}"
      },
      "warning": {
        "background": "{colors.functional.warning}",
        "backgroundLight": "rgba(245,158,11,0.12)",
        "text": "{colors.functional.warning}"
      },
      "danger": {
        "background": "{colors.functional.danger}",
        "backgroundLight": "rgba(239,68,68,0.12)",
        "text": "{colors.functional.danger}"
      },
      "info": {
        "background": "{colors.functional.info}",
        "backgroundLight": "rgba(74,159,255,0.12)",
        "text": "{colors.functional.info}"
      }
    },
    "navigation": {
      "sidebar": {
        "background": "{colors.background.secondary}",
        "item": {
          "default": {
            "background": "transparent",
            "text": "{colors.text.secondary}"
          },
          "hover": {
            "background": "{colors.background.hover}",
            "text": "{colors.text.primary}"
          },
          "active": {
            "background": "{colors.background.active}",
            "text": "{colors.accent.primary}"
          }
        }
      }
    }
  }
}